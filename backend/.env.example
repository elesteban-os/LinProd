# Archivo de configuración para desarrollo local
# Copiar como .env en el directorio backend

# FastAPI
DEBUG=True
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# WebSocket
WS_RECONNECT_INTERVAL=5
WS_MAX_MESSAGE_SIZE=1024

# Simulación
SIMULATION_TICK_INTERVAL=1  # En segundos
SIMULATION_MAX_EVENTS=20
